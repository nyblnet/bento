{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "slides-dev",
      "cwd": "slides",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5199", "--strictPort"],
      "port": 5199
    },
    {
      "name": "serve-built",
      "cwd": "slides",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "5198", "--directory", "dist-single"],
      "port": 5198
    },
    {
      "name": "serve-testing",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "5197", "--directory", "testing"],
      "port": 5197
    }
  ]
}
