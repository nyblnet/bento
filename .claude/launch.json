{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "slides-dev",
      "cwd": "slides",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--port",
        "5199",
        "--strictPort"
      ],
      "port": 5199
    },
    {
      "name": "serve-built",
      "cwd": "slides",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "5198",
        "--directory",
        "dist-single"
      ],
      "port": 5198
    },
    {
      "name": "serve-testing",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "5197",
        "--directory",
        "testing"
      ],
      "port": 5197
    },
    {
      "name": "serve-site-src",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "5192",
        "--directory",
        "site-src"
      ],
      "port": 5192
    },
    {
      "name": "serve-site",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "5195",
        "--directory",
        "site"
      ],
      "port": 5195
    },
    {
      "name": "serve-working",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "5194",
        "--directory",
        "working"
      ],
      "port": 5194
    },
    {
      "name": "serve-working2",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "--yes",
        "serve",
        "-l",
        "5193",
        "working"
      ],
      "port": 5193
    }
  ]
}